#!/usr/bin/env bash
# perf-kp-sql native dependency health check
#
# Probes:
#   - Node.js >= 18
#   - marked (require — used by md-to-html.mjs)
#   - data/kb/{cases,best-practice}/{KB.md,INDEX.md} 存在性
#
# v0.12.0: ssh2 已下线 — cli-ssh.ts 改走 spawn(本地 OpenSSH ssh CLI) +
# SSH_ASKPASS,不再需要 ssh2 native module。
#
# Output style mirrors EveryInc/ce-setup/check-health: 🟢/🔴/🟡 per item,
# with hints to fix.
#
# Modes:
#   (default)        Human-readable diagnose. Exit code = number of issues.
#   --list-missing   Suppress all human output; print one npm install spec per
#                    line for items that are absent (NOT for ABI mismatches —
#                    those need rebuild, not install). Exit 0 even if some
#                    items still need attention via rebuild.

set -o pipefail

# --list-missing: 抑制 human-readable 输出, 只把"应该 npm install 的 spec"
# 一行一个写到 stdout. 让 SKILL.md 据此精准 install, 已经存在的不再重装.
LIST_MISSING=0
for arg in "$@"; do
  case "$arg" in
    --list-missing) LIST_MISSING=1 ;;
  esac
done

PLUGIN_ROOT="${OHSQL_PLUGIN_ROOT:-}"
if [ -z "$PLUGIN_ROOT" ]; then
  # Fallback: derive from script location (skills/perf-kp-sql-setup/scripts/check-health)
  PLUGIN_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
fi

if [ ! -d "$PLUGIN_ROOT" ]; then
  msg="🔴  Cannot resolve plugin root (\$OHSQL_PLUGIN_ROOT='${OHSQL_PLUGIN_ROOT:-unset}')"
  if [ "$LIST_MISSING" = 1 ]; then echo "$msg" >&2; else echo "$msg"; fi
  exit 1
fi

cd "$PLUGIN_ROOT" || exit 1

if [ "$LIST_MISSING" = 1 ]; then
  ok()    { :; }
  warn()  { :; }
  fail()  { :; }
  hint()  { :; }
  header(){ :; }
else
  ok()    { echo "  🟢  $1"; }
  warn()  { echo "  🟡  $1"; }
  fail()  { echo "  🔴  $1"; }
  hint()  { echo "      → $1"; }
  header(){ echo ""; echo " $1"; }
fi

issues=0
needed_install=()  # npm install 候选(只装缺的, ABI mismatch 走 rebuild 不进这里)

header "Plugin"
ok "root: $PLUGIN_ROOT"
ok "name: ${OHSQL_PLUGIN_NAME:-(env unset)}"
ok "version: ${OHSQL_PLUGIN_VERSION:-(env unset)}"

header "Runtime"
NODE_VERSION="$(node --version 2>/dev/null | sed 's/v//')"
if [ -z "$NODE_VERSION" ]; then
  fail "Node.js not found"
  hint "install node >= 18"
  issues=$((issues + 1))
else
  MAJOR="${NODE_VERSION%%.*}"
  if [ "$MAJOR" -lt 18 ]; then
    fail "Node.js $NODE_VERSION (need >= 18)"
    issues=$((issues + 1))
  else
    ok "node v$NODE_VERSION"
  fi
fi

header "Native dependencies"

# ----- marked (used by scripts/md-to-html.mjs) -----
err="$(node --input-type=module -e "import('marked').then(()=>{process.stdout.write('ok')}).catch(e=>{process.stderr.write(String(e));process.exit(1)})" 2>&1)"
if [ "$err" = "ok" ]; then
  ok "marked"
else
  fail "marked missing"
  hint "fix: cd '$PLUGIN_ROOT' && npm install marked@^18"
  needed_install+=("marked@^18")
  issues=$((issues + 1))
fi

header "Data"

# ----- KB markdown files (cases + best-practice) -----
all_kb_ok=1
for kb_file in "data/kb/cases/KB.md" "data/kb/cases/INDEX.md" "data/kb/best-practice/KB.md" "data/kb/best-practice/INDEX.md"; do
  if [ ! -f "$PLUGIN_ROOT/$kb_file" ]; then
    fail "$kb_file missing"
    hint "fix: /plugin reinstall perf-kp-sql"
    issues=$((issues + 1))
    all_kb_ok=0
  fi
done
if [ "$all_kb_ok" = 1 ]; then
  ok "data/kb/ (4 files present)"
fi

# ----- NotebookLM CLI (optional enhancement) -----
nlm_installed=0
if command -v notebooklm >/dev/null 2>&1; then
  nlm_installed=1
  ok "notebooklm CLI"
  # check auth · 两层 (本地 cookie sanity + 真打 API 验 Google 侧 session)
  # 真 API 调用走 notebooklm.mjs --op check · 它内部已实现两层验证
  nlm_check_json="$(node "$PLUGIN_ROOT/scripts/notebooklm.mjs" --op check --json 2>/dev/null)"
  nlm_authed="$(echo "$nlm_check_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print('1' if d.get('authenticated') else '0')" 2>/dev/null || echo 0)"
  if [ "$nlm_authed" = "1" ]; then
    ok "notebooklm auth (Google API 验证通过)"
  else
    warn "notebooklm auth: Google 侧 cookie 过期 / 失效"
    hint "fix: 跑 'notebooklm login' 弹 Chromium 重新登录 Google 账号"
    hint "(本地 cookie 文件 sanity 可能通过 · 但 Google 侧 session 已过期)"
  fi
  # 检测 notebooklm CLI 用的 Python(可能在 venv) · 用同一个 Python 验 Playwright
  # BSD sed 不认 \s · 用 [ \t] 兼容 macOS
  nlm_python="$(head -1 "$(which notebooklm)" 2>/dev/null | sed -nE 's|^#![ 	]*([^ 	]+).*|\1|p')"
  if [ -z "$nlm_python" ] || [ ! -x "$nlm_python" ]; then
    nlm_python="python3"
  fi
  pw_check="$("$nlm_python" -c "from playwright.sync_api import sync_playwright" 2>&1)"
  if [ -z "$pw_check" ]; then
    ok "playwright Python module (用 $nlm_python 验证)"
    # check chromium installed
    pw_chromium="$("$nlm_python" -c "from playwright.sync_api import sync_playwright; p=sync_playwright().start(); b=p.chromium.launch(); b.close(); p.stop(); print('ok')" 2>&1)"
    if [ "$(echo "$pw_chromium" | tail -1)" = "ok" ]; then
      ok "playwright chromium browser"
    else
      warn "playwright chromium not installed"
      # 推断 venv 对应的 playwright 命令
      nlm_pw="$(dirname "$nlm_python")/playwright"
      [ -x "$nlm_pw" ] || nlm_pw="playwright"
      hint "fix: $nlm_pw install chromium"
      hint "(notebooklm login 需要 chromium · Google 侧 cookie 过期时无法重新登录)"
    fi
  else
    warn "playwright Python module not installed in $nlm_python"
    # 推断 venv 对应的 pip
    nlm_pip="$(echo "$nlm_python" | sed -E 's|/python[0-9.]*$|/pip|')"
    [ -x "$nlm_pip" ] || nlm_pip="pip3"
    hint "fix: $nlm_pip install 'notebooklm-py[browser]'"
    hint "(notebooklm CLI shebang 指向 $nlm_python · 必须用同一个 venv 的 pip)"
  fi
  # check config
  NLM_CFG="$HOME/.perf-kp-sql/notebooklm.json"
  if [ -f "$NLM_CFG" ]; then
    ok "notebooklm.json config present"
  else
    warn "notebooklm.json not found (notebooks not yet created)"
    hint "fix: node '$PLUGIN_ROOT/scripts/notebooklm.mjs' --op setup --json"
  fi
else
  warn "notebooklm CLI not installed (optional: NotebookLM 知识增强)"
  hint "fix: pip install 'notebooklm-py[browser]' rookiepy && playwright install chromium"
fi

# ----- --list-missing 模式: 只 emit 待装 spec, 一行一个; exit 0 -----
if [ "$LIST_MISSING" = 1 ]; then
  for p in "${needed_install[@]}"; do
    echo "$p"
  done
  exit 0
fi

# ----- summary -----
echo ""
if [ "$issues" = 0 ]; then
  echo " ✅ All required dependencies present."
else
  echo " 🔴 $issues issue(s) need attention."
fi
echo ""

exit "$issues"
