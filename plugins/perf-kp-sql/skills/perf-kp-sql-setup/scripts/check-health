#!/usr/bin/env bash
# perf-kp-sql native dependency health check
#
# Probes:
#   - Node.js >= 18
#   - better-sqlite3 (require + ABI compat)
#   - sqlite-vec (require + extension load + vec_version())
#   - @xenova/transformers (dynamic import)
#   - marked (require — used by render-html-report.mjs)
#   - data/knowledge.sqlite (file + readable + schema)
#
# v0.12.0: ssh2 已下线 — cli-ssh.ts 改走 spawn(本地 OpenSSH ssh CLI) +
# SSH_ASKPASS,不再需要 ssh2 native module。
#
# Output style mirrors EveryInc/ce-setup/check-health: 🟢/🔴/🟡 per item,
# with hints to fix.
#
# Modes:
#   (default)        Human-readable diagnose. Exit code = number of issues.
#   --list-missing   Suppress all human output; print one npm install spec per
#                    line for items that are absent (NOT for ABI mismatches —
#                    those need rebuild, not install). Exit 0 even if some
#                    items still need attention via rebuild.

set -o pipefail

# --list-missing: 抑制 human-readable 输出, 只把"应该 npm install 的 spec"
# 一行一个写到 stdout. 让 SKILL.md 据此精准 install, 已经存在的不再重装.
LIST_MISSING=0
for arg in "$@"; do
  case "$arg" in
    --list-missing) LIST_MISSING=1 ;;
  esac
done

PLUGIN_ROOT="${OHSQL_PLUGIN_ROOT:-}"
if [ -z "$PLUGIN_ROOT" ]; then
  # Fallback: derive from script location (skills/perf-kp-sql-setup/scripts/check-health)
  PLUGIN_ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
fi

if [ ! -d "$PLUGIN_ROOT" ]; then
  msg="🔴  Cannot resolve plugin root (\$OHSQL_PLUGIN_ROOT='${OHSQL_PLUGIN_ROOT:-unset}')"
  if [ "$LIST_MISSING" = 1 ]; then echo "$msg" >&2; else echo "$msg"; fi
  exit 1
fi

cd "$PLUGIN_ROOT" || exit 1

if [ "$LIST_MISSING" = 1 ]; then
  ok()    { :; }
  warn()  { :; }
  fail()  { :; }
  hint()  { :; }
  header(){ :; }
else
  ok()    { echo "  🟢  $1"; }
  warn()  { echo "  🟡  $1"; }
  fail()  { echo "  🔴  $1"; }
  hint()  { echo "      → $1"; }
  header(){ echo ""; echo " $1"; }
fi

issues=0
needed_install=()  # npm install 候选(只装缺的, ABI mismatch 走 rebuild 不进这里)

header "Plugin"
ok "root: $PLUGIN_ROOT"
ok "name: ${OHSQL_PLUGIN_NAME:-(env unset)}"
ok "version: ${OHSQL_PLUGIN_VERSION:-(env unset)}"

header "Runtime"
NODE_VERSION="$(node --version 2>/dev/null | sed 's/v//')"
if [ -z "$NODE_VERSION" ]; then
  fail "Node.js not found"
  hint "install node >= 18"
  issues=$((issues + 1))
else
  MAJOR="${NODE_VERSION%%.*}"
  if [ "$MAJOR" -lt 18 ]; then
    fail "Node.js $NODE_VERSION (need >= 18)"
    issues=$((issues + 1))
  else
    ok "node v$NODE_VERSION"
  fi
fi

header "Native dependencies"

# ----- better-sqlite3 -----
err="$(node -e "require('better-sqlite3')" 2>&1)"
if [ -z "$err" ]; then
  abi_err="$(node -e "const D=require('better-sqlite3'); new D(':memory:').prepare('SELECT 1').get();" 2>&1)"
  if [ -z "$abi_err" ]; then
    ok "better-sqlite3"
  else
    fail "better-sqlite3 ABI mismatch"
    hint "$abi_err"
    hint "fix: cd '$PLUGIN_ROOT' && npm rebuild better-sqlite3"
    issues=$((issues + 1))
  fi
else
  fail "better-sqlite3 missing"
  hint "fix: cd '$PLUGIN_ROOT' && npm install better-sqlite3@^11.7"
  needed_install+=("better-sqlite3@^11.7")
  issues=$((issues + 1))
fi

# ----- sqlite-vec (extension load) -----
vec_err="$(node -e "
const D = require('better-sqlite3');
const v = require('sqlite-vec');
const db = new D(':memory:');
v.load(db);
const r = db.prepare('SELECT vec_version() AS v').get();
process.stdout.write(r.v);
" 2>&1)"
if [[ "$vec_err" =~ ^v[0-9] ]]; then
  ok "sqlite-vec ($vec_err)"
else
  fail "sqlite-vec extension load failed"
  hint "$vec_err"
  hint "fix: cd '$PLUGIN_ROOT' && npm install sqlite-vec@^0.1"
  needed_install+=("sqlite-vec@^0.1")
  issues=$((issues + 1))
fi

# ----- @xenova/transformers -----
err="$(node --input-type=module -e "import('@xenova/transformers').then(()=>{process.stdout.write('ok')}).catch(e=>{process.stderr.write(String(e));process.exit(1)})" 2>&1)"
if [ "$err" = "ok" ]; then
  ok "@xenova/transformers"
else
  fail "@xenova/transformers missing or broken"
  hint "fix: cd '$PLUGIN_ROOT' && npm install @xenova/transformers@^2.17"
  needed_install+=("@xenova/transformers@^2.17")
  issues=$((issues + 1))
fi

# ----- marked (used by scripts/render-html-report.mjs) -----
err="$(node --input-type=module -e "import('marked').then(()=>{process.stdout.write('ok')}).catch(e=>{process.stderr.write(String(e));process.exit(1)})" 2>&1)"
if [ "$err" = "ok" ]; then
  ok "marked"
else
  fail "marked missing"
  hint "fix: cd '$PLUGIN_ROOT' && npm install marked@^18"
  needed_install+=("marked@^18")
  issues=$((issues + 1))
fi

header "Data"

# ----- knowledge.sqlite -----
KB="$PLUGIN_ROOT/data/knowledge.sqlite"
if [ ! -f "$KB" ]; then
  fail "data/knowledge.sqlite missing"
  hint "fix: /plugin reinstall perf-kp-sql"
  issues=$((issues + 1))
else
  schema_err="$(node -e "
  const D = require('better-sqlite3');
  const db = new D('$KB', { readonly: true });
  for (const t of ['knowledge','rules','flame_patterns']) {
    const r = db.prepare(\`SELECT count(*) AS c FROM \${t}\`).get();
    if (typeof r.c !== 'number') throw new Error(t + ' missing');
  }
  process.stdout.write('ok');
  " 2>&1)"
  if [ "$schema_err" = "ok" ]; then
    ok "knowledge.sqlite (schema verified)"
  else
    fail "knowledge.sqlite corrupt or schema mismatch"
    hint "$schema_err"
    hint "fix: /plugin reinstall perf-kp-sql"
    issues=$((issues + 1))
  fi
fi

# ----- model cache (informational) -----
HF_CACHE="${HF_HOME:-$HOME/.cache/huggingface}"
if [ -d "$HF_CACHE" ] && find "$HF_CACHE" -name "*MiniLM*" -type d 2>/dev/null | grep -q .; then
  ok "MiniLM-L6-v2 cached at $HF_CACHE"
else
  warn "MiniLM-L6-v2 not cached (~25MB; downloads on first KB query)"
  hint "warmup: node '$PLUGIN_ROOT/scripts/kb.mjs' --op embed --text warmup"
fi

# ----- --list-missing 模式: 只 emit 待装 spec, 一行一个; exit 0 -----
if [ "$LIST_MISSING" = 1 ]; then
  for p in "${needed_install[@]}"; do
    echo "$p"
  done
  exit 0
fi

# ----- summary -----
echo ""
if [ "$issues" = 0 ]; then
  echo " ✅ All required dependencies present."
else
  echo " 🔴 $issues issue(s) need attention."
fi
echo ""

exit "$issues"
