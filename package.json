{
  "name": "@ohsql/plugin-marketplace",
  "version": "1.0.0",
  "description": "Repo-internal tooling for the ohsql-plugin marketplace (CI build only — not consumed by plugin runtime)",
  "type": "module",
  "private": true,
  "scripts": {
    "validate": "node tools/build/validate.mjs",
    "validate:strict": "node tools/build/validate.mjs --strict",
    "test": "npm run test:validate && npm run test:perf-kp-sql",
    "test:validate": "node --test tools/build/validate.test.mjs",
    "test:perf-kp-sql": "node --import tsx --test plugins/perf-kp-sql/tests/cli-ssh.test.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "cheerio": "^1.2.0",
    "esbuild": "^0.27.4",
    "handlebars": "^4.7.9",
    "marked": "^18.0.2",
    "openai": "^4.72.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "sqlite-vec": "^0.1.6"
  }
}
